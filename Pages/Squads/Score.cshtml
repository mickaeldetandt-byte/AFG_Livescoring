@page
@model AFG_Livescoring.Pages.Squads.ScoreModel
@{
    ViewData["Title"] = "Scoring Squad";
}

<style>
    .score-page {
        max-width: 820px;
        margin: 0 auto;
    }

    .hole-header,
    .score-card,
    .player-row {
        border-radius: 18px;
    }

    .score-card {
        border: none;
    }

    .player-row {
        padding: 16px;
        margin-bottom: 14px;
        background: #fff;
    }

    .player-name {
        font-size: 1.08rem;
        font-weight: 800;
        line-height: 1.2;
    }

    .player-sub {
        font-size: 0.85rem;
        color: #6c757d;
        margin-top: 4px;
    }

    .score-controls {
        display: flex;
        align-items: center;
        gap: 14px;
    }

    .score-btn {
        width: 60px;
        height: 60px;
        font-size: 1.9rem;
        font-weight: 800;
        padding: 0;
        border-radius: 16px;
        touch-action: manipulation;
    }

    .score-value {
        min-width: 58px;
        text-align: center;
        font-size: 2.1rem;
        font-weight: 900;
        line-height: 1;
    }

    .action-btn {
        min-height: 56px;
        font-size: 1.05rem;
        font-weight: 700;
        border-radius: 14px;
        touch-action: manipulation;
    }

    .badge-lg {
        font-size: 0.92rem;
        padding: 0.6em 0.85em;
        border-radius: 12px;
    }

    .hole-title {
        font-size: 2rem;
        font-weight: 900;
        line-height: 1.1;
    }

    .hole-meta {
        font-size: 0.95rem;
        color: #6c757d;
    }

    .sticky-actions {
        position: sticky;
        bottom: 10px;
        z-index: 20;
        margin-top: 18px;
    }

    .sticky-actions-inner {
        background: rgba(255,255,255,0.96);
        backdrop-filter: blur(8px);
        border-radius: 18px;
        padding: 12px;
        box-shadow: 0 8px 24px rgba(0,0,0,0.08);
    }

    @@media (max-width: 576px) {
        .container {
            padding-left: 10px;
            padding-right: 10px;
        }

        .score-page h3 {
            font-size: 1.35rem;
        }

        .hole-title {
            font-size: 1.75rem;
        }

        .player-row {
            padding: 14px;
        }

        .player-name {
            font-size: 1rem;
            max-width: 150px;
        }

        .score-controls {
            gap: 10px;
        }

        .score-btn {
            width: 64px;
            height: 64px;
            font-size: 2rem;
        }

        .score-value {
            min-width: 60px;
            font-size: 2.15rem;
        }

        .action-btn {
            min-height: 60px;
            font-size: 1.08rem;
        }
    }
</style>

<div class="container mt-3 mb-4 score-page">

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-warning shadow-sm">@TempData["Error"]</div>
    }

    @if (TempData["Info"] != null)
    {
        <div class="alert alert-info shadow-sm">@TempData["Info"]</div>
    }

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success shadow-sm">@TempData["Success"]</div>
    }

    <div class="d-flex justify-content-between align-items-start gap-2 mb-3 flex-wrap">
        <div>
            <h3 class="mb-1">Scoring Squad</h3>
            <div class="text-muted">
                Compétition : <strong>@Model.Competition?.Name</strong>
            </div>
            <div class="text-muted">
                Squad : <strong>@Model.Squad?.Name</strong>
            </div>
        </div>

        <a class="btn btn-outline-secondary action-btn"
               href="/Leaderboard?competitionId=@Model.CompetitionId">
            Retour Live
        </a>
    </div>

    @if (Model.IsSquadLocked)
    {
        <div class="alert alert-warning shadow-sm">
            <strong>Carte validée.</strong> Modification impossible.
        </div>
    }

    <div class="card hole-header shadow-sm mb-3">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
                <div>
                    <div class="hole-title">
                        Trou @Model.CurrentHole / 18
                    </div>

                    <div class="hole-meta mt-1">
                        @if (Model.CurrentPar.HasValue)
                        {
                            <span>Par <strong>@Model.CurrentPar</strong></span>
                        }
                        <span class="ms-2">•</span>
                        <span class="ms-2">StartHole <strong>@Model.Squad?.StartHole</strong></span>
                    </div>

                    <div class="mt-3 d-flex flex-wrap gap-2">
                        @if (Model.IsHoleValidated)
                        {
                            <span class="badge bg-success badge-lg">VALIDÉ</span>
                        }
                        else
                        {
                            <span class="badge bg-warning text-dark badge-lg">EN COURS</span>
                        }

                        @if (Model.Edit && !Model.IsSquadLocked)
                        {
                            <span class="badge bg-danger badge-lg">MODE CORRECTION</span>
                        }

                        @if (Model.IsSquadLocked)
                        {
                            <span class="badge bg-dark badge-lg">CARTE VALIDÉE</span>
                        }
                    </div>
                </div>

                <div class="d-flex gap-2 flex-wrap">
                    @if (Model.CurrentHole > 1)
                    {
                        <a class="btn btn-outline-primary action-btn"
                               href="/Squads/Score?competitionId=@Model.CompetitionId&squadId=@Model.SquadId&hole=@(Model.CurrentHole - 1)&edit=@Model.Edit&token=@Model.Token">
                            ← Trou précédent
                        </a>
                    }

                    @if (Model.CurrentHole < 18)
                    {
                        <a class="btn btn-outline-primary action-btn"
                               href="/Squads/Score?competitionId=@Model.CompetitionId&squadId=@Model.SquadId&hole=@(Model.CurrentHole + 1)&edit=@Model.Edit&token=@Model.Token">
                            Trou suivant →
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="card score-card shadow-sm">
        <div class="card-body">
            <h5 class="mb-3">Joueurs</h5>

            <form method="post">
                <input type="hidden" asp-for="CompetitionId" />
                <input type="hidden" asp-for="SquadId" />
                <input type="hidden" asp-for="CurrentHole" />
                <input type="hidden" asp-for="Edit" />
                <input type="hidden" asp-for="Token" />

                @foreach (var p in Model.Players)
                {
                    <input type="hidden"
                           name="Scores[@p.RoundId]"
                           id="input-@p.RoundId"
                           value="@p.Strokes" />

                    <div class="d-flex justify-content-between align-items-center border shadow-sm player-row">
                        <div class="me-2">
                            <div class="player-name">@p.PlayerName</div>
                            <div class="player-sub">Score trou @Model.CurrentHole</div>
                        </div>

                        <div class="score-controls">
                            <button type="button"
                                    class="btn btn-outline-secondary score-btn"
                                    onclick="if(preventDoubleTap()) decrement(@p.RoundId)"
                                @(Model.IsSquadLocked || (Model.IsHoleValidated && !Model.Edit) ? "disabled" : "")>
                                −
                            </button>

                            <span id="score-@p.RoundId" class="score-value">
                                @p.Strokes
                            </span>

                            <button type="button"
                                    class="btn btn-outline-secondary score-btn"
                                    onclick="if(preventDoubleTap()) increment(@p.RoundId)"
                                @(Model.IsSquadLocked || (Model.IsHoleValidated && !Model.Edit) ? "disabled" : "")>
                                +
                            </button>
                        </div>
                    </div>
                }

                <div class="sticky-actions">
                    <div class="sticky-actions-inner">
                        @if (Model.IsSquadLocked)
                        {
                            <div class="text-muted mb-3">
                                Saisie désactivée. La carte a été validée officiellement.
                            </div>
                        }
                        else if (Model.IsHoleValidated && !Model.Edit)
                        {
                            <div class="alert alert-warning mb-3">
                                Ce trou est déjà validé.
                            </div>

                            <div class="d-grid gap-2">
                                <button type="submit"
                                        formaction="?handler=Correct"
                                        class="btn btn-outline-danger action-btn">
                                    Corriger ce trou
                                </button>

                                @if (Model.CurrentHole >= 18)
                                {
                                    <button type="submit"
                                            formaction="?handler=LockCard"
                                            class="btn btn-dark action-btn">
                                        Valider la carte
                                    </button>

                                    <a class="btn btn-primary action-btn"
                                           href="/Leaderboard?competitionId=@Model.CompetitionId">
                                        Retour Live
                                    </a>
                                }
                                else
                                {
                                    <a class="btn btn-primary action-btn"
                                           href="/Squads/Score?competitionId=@Model.CompetitionId&squadId=@Model.SquadId&hole=@(Model.CurrentHole + 1)&token=@Model.Token">
                                        Trou suivant
                                    </a>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="d-grid">
                                <button type="submit"
                                        class="btn @(Model.Edit ? "btn-warning" : "btn-success") action-btn w-100">
                                    @(Model.Edit ? "Enregistrer la correction" : "Valider le trou")
                                </button>
                            </div>
                        }
                    </div>
                </div>
            </form>

            @if (Model.IsSquadLocked)
            {
                <form method="post"
                      asp-page="/Squads/Score"
                      asp-page-handler="Unlock"
                      asp-route-competitionId="@Model.CompetitionId"
                      asp-route-squadId="@Model.SquadId"
                      asp-route-hole="@Model.CurrentHole"
                      asp-route-token="@Model.Token"
                      class="mt-3">

                    <button type="submit"
                            class="btn btn-outline-danger action-btn w-100">
                        Déverrouiller (organisateur)
                    </button>
                </form>
            }
        </div>
    </div>
</div>

<script>
    let lastTap = 0;

    function preventDoubleTap() {
        const now = Date.now();

        if (now - lastTap < 300) {
            return false;
        }

        lastTap = now;
        return true;
    }

    function setScore(roundId, value) {
        if (value < 0) value = 0;
        if (value > 10) value = 10;

        document.getElementById("score-" + roundId).innerText = value;
        document.getElementById("input-" + roundId).value = value;
    }

    function increment(id) {
        let val = parseInt(document.getElementById("score-" + id).innerText);
        setScore(id, val + 1);
    }

    function decrement(id) {
        let val = parseInt(document.getElementById("score-" + id).innerText);
        setScore(id, val - 1);
    }
</script>