@page
@model AFG_Livescoring.Pages.Squads.ManageModel
@{
    ViewData["Title"] = "Gestion des squads";
}

<div class="container mt-4">

    @if (TempData["Message"] != null)
    {
        <div class="alert alert-info">
            @TempData["Message"]
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.LockMessage))
    {
        <div class="alert alert-warning">
            @Model.LockMessage
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-0">Gestion des squads</h2>
            <div class="text-muted">@Model.CompetitionName</div>
        </div>

        <a class="btn btn-outline-secondary" href="/Competitions">
            Retour
        </a>
    </div>

    <div class="mb-3 d-flex flex-wrap gap-2">
        @if (Model.IsTraining)
        {
            <span class="badge bg-info text-dark">Mode entraînement</span>
        }
        else
        {
            <span class="badge bg-primary">Mode compétition</span>
        }

        @if (Model.IsMatchPlayCompetition)
        {
            <span class="badge bg-dark">Mode Match Play</span>
        }

        <span class="badge bg-secondary">
            Taille squads : @Model.MinSquadSize à @Model.MaxSquadSize
        </span>

        @if (Model.HasScores)
        {
            <span class="badge bg-warning text-dark">Scores détectés</span>
        }
        else
        {
            <span class="badge bg-success">Aucun score saisi</span>
        }
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <h4 class="mb-3">Actions</h4>

            @if (Model.CanEditSquads)
            {
                <form method="post" asp-page-handler="Generate" class="row g-3 align-items-end mb-3">
                    <input type="hidden" name="competitionId" value="@Model.CompetitionId" />

                    <div class="col-md-4">
                        <label class="form-label">Taille des squads</label>
                        <select name="squadSize" class="form-select">
                            @for (int size = Model.MinSquadSize; size <= Model.MaxSquadSize; size++)
                            {
                                <option value="@size">@size joueur(s)</option>
                            }
                        </select>
                    </div>

                    <div class="col-md-8 d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            Générer les squads
                        </button>
                    </div>
                </form>

                <div class="d-flex flex-wrap gap-2">
                    <form method="post" asp-page-handler="Clear" class="m-0">
                        <input type="hidden" name="competitionId" value="@Model.CompetitionId" />
                        <button type="submit"
                                class="btn btn-outline-danger"
                                onclick="return confirm('Réinitialiser les squads ?');">
                            Réinitialiser
                        </button>
                    </form>

                    @if (Model.IsTraining)
                    {
                        <form method="post" asp-page-handler="CreateSquad" class="m-0">
                            <input type="hidden" name="competitionId" value="@Model.CompetitionId" />
                            <button type="submit" class="btn btn-outline-primary">
                                Créer un squad vide
                            </button>
                        </form>
                    }
                </div>
            }
            else
            {
                <div class="d-flex flex-wrap gap-2">
                    <button type="button" class="btn btn-secondary" disabled>
                        Génération verrouillée
                    </button>

                    <button type="button" class="btn btn-outline-secondary" disabled>
                        Réinitialisation verrouillée
                    </button>
                </div>
            }
        </div>
    </div>

    @if (Model.IsTraining && Model.UnassignedRounds.Any())
    {
        <div class="card shadow-sm mb-4">
            <div class="card-body">
                <h4 class="mb-3">Joueurs non affectés</h4>

                <div class="table-responsive">
                    <table class="table table-striped align-middle">
                        <thead>
                            <tr>
                                <th>Joueur</th>
                                <th style="width: 240px;">Affecter à</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var round in Model.UnassignedRounds)
                            {
                                <tr>
                                    <td>
                                        @if (round.Player != null)
                                        {
                                            @($"{round.Player.FirstName} {round.Player.LastName}")
                                        }
                                        else
                                        {
                                            @($"PlayerId={round.PlayerId}")
                                        }
                                    </td>
                                    <td>
                                        @if (Model.Squads.Any())
                                        {
                                            <form method="post" asp-page-handler="Assign" class="d-flex gap-2">
                                                <input type="hidden" name="competitionId" value="@Model.CompetitionId" />
                                                <input type="hidden" name="roundId" value="@round.Id" />

                                                <select name="squadId" class="form-select form-select-sm">
                                                    @foreach (var squad in Model.Squads)
                                                    {
                                                        <option value="@squad.Id">@squad.Name</option>
                                                    }
                                                </select>

                                                <button type="submit" class="btn btn-sm btn-primary">
                                                    Affecter
                                                </button>
                                            </form>
                                        }
                                        else
                                        {
                                            <span class="text-muted">Aucun squad disponible</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }

    @if (!Model.Squads.Any())
    {
        <div class="alert alert-secondary">
            Aucun squad généré pour le moment.
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var squad in Model.Squads)
            {
                var orderedRounds = squad.Rounds
                .OrderBy(r => r.Player!.LastName)
                .ThenBy(r => r.Player!.FirstName)
                .ToList();

                var existingTeam1 = squad.Teams.ElementAtOrDefault(0);
                var existingTeam2 = squad.Teams.ElementAtOrDefault(1);

                <div class="col-lg-6">
                    <div class="card shadow-sm h-100">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <div>
                                    <h4 class="mb-0">@squad.Name</h4>
                                    <div class="text-muted">Départ trou @squad.StartHole</div>
                                </div>
                                <span class="badge bg-dark">@squad.Rounds.Count joueur(s)</span>
                            </div>

                            @if (!squad.Rounds.Any())
                            {
                                <div class="text-muted">Aucun joueur dans ce squad.</div>
                            }
                            else
                            {
                                <ul class="list-group list-group-flush">
                                    @foreach (var round in orderedRounds)
                                    {
                                        <li class="list-group-item px-0 d-flex justify-content-between align-items-center">
                                            <span>
                                                @if (round.Player != null)
                                                {
                                                    @($"{round.Player.FirstName} {round.Player.LastName}")
                                                }
                                                else
                                                {
                                                    @($"PlayerId={round.PlayerId}")
                                                }
                                            </span>

                                            @if (Model.IsTraining)
                                            {
                                                <form method="post" asp-page-handler="Remove" class="m-0">
                                                    <input type="hidden" name="competitionId" value="@Model.CompetitionId" />
                                                    <input type="hidden" name="roundId" value="@round.Id" />
                                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                                        Retirer
                                                    </button>
                                                </form>
                                            }
                                        </li>
                                    }
                                </ul>

                                @if (Model.IsMatchPlayDoubles && squad.Rounds.Count == 4)
                                {
                                    <div class="mt-4">
                                        <h5 class="mb-3">Composition des équipes</h5>

                                        <form method="post" asp-page-handler="SaveTeams" class="row g-3">
                                            <input type="hidden" name="competitionId" value="@Model.CompetitionId" />
                                            <input type="hidden" name="squadId" value="@squad.Id" />

                                            <div class="col-12">
                                                <div class="fw-semibold mb-2">Équipe 1</div>
                                            </div>

                                            <div class="col-md-6">
                                                <label class="form-label">Joueur 1</label>
                                                <select name="team1p1" class="form-select">
                                                    @foreach (var round in orderedRounds)
                                                    {
                                                        var selected = existingTeam1?.Player1Id == round.PlayerId
                                                        || (existingTeam1 == null && orderedRounds.IndexOf(round) == 0);

                                                        if (selected)
                                                        {
                                                            <option value="@round.PlayerId" selected>
                                                                @($"{round.Player!.FirstName} {round.Player.LastName}")
                                                            </option>
                                                        }
                                                        else
                                                        {
                                                            <option value="@round.PlayerId">
                                                                @($"{round.Player!.FirstName} {round.Player.LastName}")
                                                            </option>
                                                        }
                                                    }
                                                </select>
                                            </div>

                                            <div class="col-md-6">
                                                <label class="form-label">Joueur 2</label>
                                                <select name="team1p2" class="form-select">
                                                    @foreach (var round in orderedRounds)
                                                    {
                                                        var selected = existingTeam1?.Player2Id == round.PlayerId
                                                        || (existingTeam1 == null && orderedRounds.IndexOf(round) == 1);

                                                        if (selected)
                                                        {
                                                            <option value="@round.PlayerId" selected>
                                                                @($"{round.Player!.FirstName} {round.Player.LastName}")
                                                            </option>
                                                        }
                                                        else
                                                        {
                                                            <option value="@round.PlayerId">
                                                                @($"{round.Player!.FirstName} {round.Player.LastName}")
                                                            </option>
                                                        }
                                                    }
                                                </select>
                                            </div>

                                            <div class="col-12 mt-2">
                                                <div class="fw-semibold mb-2">Équipe 2</div>
                                            </div>

                                            <div class="col-md-6">
                                                <label class="form-label">Joueur 1</label>
                                                <select name="team2p1" class="form-select">
                                                    @foreach (var round in orderedRounds)
                                                    {
                                                        var selected = existingTeam2?.Player1Id == round.PlayerId
                                                        || (existingTeam2 == null && orderedRounds.IndexOf(round) == 2);

                                                        if (selected)
                                                        {
                                                            <option value="@round.PlayerId" selected>
                                                                @($"{round.Player!.FirstName} {round.Player.LastName}")
                                                            </option>
                                                        }
                                                        else
                                                        {
                                                            <option value="@round.PlayerId">
                                                                @($"{round.Player!.FirstName} {round.Player.LastName}")
                                                            </option>
                                                        }
                                                    }
                                                </select>
                                            </div>

                                            <div class="col-md-6">
                                                <label class="form-label">Joueur 2</label>
                                                <select name="team2p2" class="form-select">
                                                    @foreach (var round in orderedRounds)
                                                    {
                                                        var selected = existingTeam2?.Player2Id == round.PlayerId
                                                        || (existingTeam2 == null && orderedRounds.IndexOf(round) == 3);

                                                        if (selected)
                                                        {
                                                            <option value="@round.PlayerId" selected>
                                                                @($"{round.Player!.FirstName} {round.Player.LastName}")
                                                            </option>
                                                        }
                                                        else
                                                        {
                                                            <option value="@round.PlayerId">
                                                                @($"{round.Player!.FirstName} {round.Player.LastName}")
                                                            </option>
                                                        }
                                                    }
                                                </select>
                                            </div>

                                            <div class="col-12 d-flex gap-2 mt-3">
                                                <button type="submit" class="btn btn-outline-primary btn-sm">
                                                    Enregistrer les équipes
                                                </button>
                                            </div>
                                        </form>

                                        @if (squad.Teams.Any())
                                        {
                                            <div class="mt-3">
                                                <div class="small text-muted mb-2">Équipes enregistrées :</div>
                                                <ul class="list-group list-group-flush">
                                                    @foreach (var team in squad.Teams)
                                                    {
                                                        <li class="list-group-item px-0">
                                                            <strong>@team.Name</strong>
                                                        </li>
                                                    }
                                                </ul>
                                            </div>
                                        }
                                    </div>
                                }

                                @if (Model.IsMatchPlayCompetition)
                                {
                                    <div class="mt-3 d-flex gap-2">
                                        <form method="post" asp-page-handler="GenerateMatchPlay" class="m-0">
                                            <input type="hidden" name="competitionId" value="@Model.CompetitionId" />
                                            <input type="hidden" name="squadId" value="@squad.Id" />
                                            <button type="submit" class="btn btn-dark btn-sm">
                                                Générer Match Play
                                            </button>
                                        </form>
                                    </div>
                                }

                                @if (Model.IsMatchPlayCompetition && squad.MatchPlayRounds.Any())
                                {
                                    <div class="mt-4">
                                        <h5 class="mb-3">Matchs Match Play</h5>

                                        <div class="table-responsive">
                                            <table class="table table-sm table-bordered align-middle">
                                                <thead class="table-light">
                                                    <tr>
                                                        <th>Match</th>
                                                        <th style="width: 90px;">Trou</th>
                                                        <th style="width: 180px;">Statut</th>
                                                        <th style="width: 120px;">Résultat</th>
                                                        <th style="width: 110px;">Action</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @foreach (var match in squad.MatchPlayRounds)
                                                    {
                                                        var teamAName = string.Join(" / ",
                                                        match.TeamA?.TeamPlayers?
                                                        .OrderBy(x => x.Order)
                                                        .Select(x => $"{x.Player!.FirstName} {x.Player.LastName}")
                                                        ?? new List<string>());

                                                        var teamBName = string.Join(" / ",
                                                        match.TeamB?.TeamPlayers?
                                                        .OrderBy(x => x.Order)
                                                        .Select(x => $"{x.Player!.FirstName} {x.Player.LastName}")
                                                        ?? new List<string>());

                                                        <tr>
                                                            <td>
                                                                <strong>@teamAName</strong> vs <strong>@teamBName</strong>
                                                            </td>
                                                            <td>
                                                                @if (match.IsFinished)
                                                                {
                                                                    <span class="badge bg-success">18 joués</span>
                                                                }
                                                                else
                                                                {
                                                                    @match.CurrentHole
                                                                }
                                                            </td>
                                                            <td>@match.StatusText</td>
                                                            <td>@(string.IsNullOrWhiteSpace(match.ResultText) ? "-" : match.ResultText)</td>
                                                            <td>
                                                                <a class="btn btn-sm btn-success"
                                                                   href="/MatchPlayScore?matchId=@match.Id">
                                                                    Scorer
                                                                </a>
                                                            </td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                }
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }

</div>