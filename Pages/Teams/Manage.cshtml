@page
@model AFG_Livescoring.Pages.Teams.ManageModel
@{
    ViewData["Title"] = "Gestion des équipes";
}

<div class="container mt-4">

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-warning">
            @TempData["Error"]
        </div>
    }

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">
            @TempData["SuccessMessage"]
        </div>
    }

    @if (Model.Competition == null)
    {
        <div class="alert alert-danger">Compétition introuvable.</div>
    }
    else
    {
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="mb-1">Équipes doubles</h2>
                <div class="text-muted">
                    <strong>@Model.Competition.Name</strong> —
                    @Model.Competition.Date.ToString("dd/MM/yyyy")
                </div>
            </div>

            <div class="d-flex gap-2">
                <a class="btn btn-outline-secondary"
                   href="/CompetitionParticipants?competitionId=@Model.CompetitionId">
                    Participants
                </a>

                <a class="btn btn-outline-primary"
                   href="/Competitions">
                    Retour compétitions
                </a>
            </div>
        </div>

        @if (!Model.IsDoublesCompetition)
        {
            <div class="alert alert-warning">
                Cette compétition n'est pas un format doubles.
            </div>
        }
        else
        {
            <div class="row g-4 mb-4">
                <div class="col-lg-6">
                    <div class="card h-100">
                        <div class="card-header">
                            <strong>Créer une équipe manuellement</strong>
                        </div>
                        <div class="card-body">
                            <form method="post" asp-page-handler="Add" class="row g-3">
                                <input type="hidden" asp-for="CompetitionId" />

                                <div class="col-12">
                                    <label asp-for="TeamName" class="form-label">Nom équipe</label>
                                    <input asp-for="TeamName" class="form-control" placeholder="Laisser vide pour nom automatique" />
                                    <div class="form-text">
                                        Si vide, le nom sera généré automatiquement avec les 2 joueurs.
                                    </div>
                                </div>

                                <div class="col-md-6">
                                    <label asp-for="Player1Id" class="form-label">Joueur 1</label>
                                    <select asp-for="Player1Id" class="form-select">
                                        <option value="">-- Sélectionner --</option>
                                        @foreach (var p in Model.AvailablePlayers)
                                        {
                                            <option value="@p.Id">@p.FirstName @p.LastName</option>
                                        }
                                    </select>
                                </div>

                                <div class="col-md-6">
                                    <label asp-for="Player2Id" class="form-label">Joueur 2</label>
                                    <select asp-for="Player2Id" class="form-select">
                                        <option value="">-- Sélectionner --</option>
                                        @foreach (var p in Model.AvailablePlayers)
                                        {
                                            <option value="@p.Id">@p.FirstName @p.LastName</option>
                                        }
                                    </select>
                                </div>

                                <div class="col-12">
                                    <button type="submit" class="btn btn-primary w-100">Créer l'équipe</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>

                <div class="col-lg-3">
                    <div class="card h-100">
                        <div class="card-header">
                            <strong>Génération auto équipes</strong>
                        </div>
                        <div class="card-body d-flex flex-column justify-content-between">
                            <div class="mb-3">
                                <div class="text-muted small">
                                    Crée automatiquement les équipes de 2 avec les participants non encore utilisés.
                                </div>
                            </div>

                            <form method="post" asp-page-handler="GenerateTeams">
                                <input type="hidden" asp-for="CompetitionId" />
                                <button type="submit" class="btn btn-success w-100"
                                        onclick="return confirm('Générer automatiquement les équipes disponibles ?');">
                                    Générer équipes
                                </button>
                            </form>
                        </div>
                    </div>
                </div>

                <div class="col-lg-3">
                    <div class="card h-100">
                        <div class="card-header">
                            <strong>Génération auto squads</strong>
                        </div>
                        <div class="card-body d-flex flex-column justify-content-between">
                            <form method="post" asp-page-handler="GenerateSquads" class="row g-3">
                                <input type="hidden" asp-for="CompetitionId" />

                                <div class="col-12">
                                    <label asp-for="TeamsPerSquad" class="form-label">Équipes par squad</label>
                                    <select asp-for="TeamsPerSquad" class="form-select">
                                        <option value="2">2 équipes</option>
                                        <option value="3">3 équipes</option>
                                        <option value="4">4 équipes</option>
                                    </select>
                                </div>

                                <div class="col-12">
                                    <button type="submit" class="btn btn-warning w-100"
                                            onclick="return confirm('Regénérer automatiquement les squads ? Les affectations actuelles seront remplacées.');">
                                        Générer squads
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="text-danger mb-3">
                    @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <div>@err.ErrorMessage</div>
                    }
                </div>
            }

            <div class="card mb-4">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <strong>Équipes existantes</strong>
                    <span class="badge bg-secondary">@Model.Teams.Count</span>
                </div>

                <div class="card-body p-0">
                    <table class="table table-striped table-bordered align-middle mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th style="width:90px;">Id</th>
                                <th>Équipe</th>
                                <th>Joueurs</th>
                                <th style="width:90px;">Nb</th>
                                <th style="width:140px;">Squad</th>
                                <th style="width:140px;">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!Model.Teams.Any())
                            {
                                <tr>
                                    <td colspan="6" class="text-center text-muted">
                                        Aucune équipe créée
                                    </td>
                                </tr>
                            }
                            else
                            {
                                foreach (var team in Model.Teams)
                                {
                                    <tr>
                                        <td>@team.TeamId</td>
                                        <td>@team.TeamName</td>
                                        <td>@team.PlayersDisplay</td>
                                        <td>@team.PlayerCount</td>
                                        <td>@team.SquadDisplay</td>
                                        <td>
                                            <form method="post"
                                                  asp-page-handler="Delete"
                                                  asp-route-competitionId="@Model.CompetitionId"
                                                  asp-route-teamId="@team.TeamId"
                                                  class="m-0">
                                                <button type="submit"
                                                        class="btn btn-danger btn-sm w-100"
                                                        onclick="return confirm('Supprimer cette équipe ?');">
                                                    Supprimer
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <strong>Squads existants</strong>
                    <span class="badge bg-secondary">@Model.ExistingSquads.Count</span>
                </div>
                <div class="card-body p-0">
                    <table class="table table-striped table-bordered align-middle mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th style="width:100px;">Id</th>
                                <th>Nom</th>
                                <th style="width:140px;">Trou départ</th>
                                <th style="width:160px;">Heure départ</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!Model.ExistingSquads.Any())
                            {
                                <tr>
                                    <td colspan="4" class="text-center text-muted">Aucun squad</td>
                                </tr>
                            }
                            else
                            {
                                foreach (var squad in Model.ExistingSquads)
                                {
                                    <tr>
                                        <td>@squad.Id</td>
                                        <td>@squad.Name</td>
                                        <td>@squad.StartHole</td>
                                        <td>@(squad.StartTime?.ToString(@"hh\:mm") ?? "-")</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    }
</div>