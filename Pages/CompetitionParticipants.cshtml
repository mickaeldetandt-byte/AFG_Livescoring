@page
@model AFG_Livescoring.Pages.CompetitionParticipantsModel
@{
    ViewData["Title"] = "Participants compétition";
}

<div class="container mt-4">

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-warning">
            @TempData["Error"]
        </div>
    }

    @if (Model.Competition == null)
    {
        <div class="alert alert-danger">
            Compétition introuvable.
        </div>
        return;
    }

    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h2 class="mb-1">Participants - @Model.Competition.Name</h2>
            <div class="text-muted">
                Date : @Model.Competition.Date.ToString("dd/MM/yyyy")
            </div>
        </div>

        <a class="btn btn-outline-secondary"
           href="/Competitions">
            Retour
        </a>
    </div>

    <div class="mb-3 d-flex flex-wrap gap-2">
        @if (Model.IsTraining)
        {
            <span class="badge bg-info text-dark">Mode entraînement</span>
        }
        else
        {
            <span class="badge bg-primary">Mode compétition</span>
        }

        @if (Model.HasStarted)
        {
            <span class="badge bg-warning text-dark">Session démarrée</span>
        }
        else
        {
            <span class="badge bg-secondary">Non démarrée</span>
        }

        @if (Model.HasSquads)
        {
            <span class="badge bg-dark">Squads générés</span>
        }
    </div>

    @if (!Model.CanEditParticipants && !string.IsNullOrWhiteSpace(Model.LockMessage))
    {
        <div class="alert alert-info">
            @Model.LockMessage
        </div>
    }

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <h4 class="mb-3">Ajouter un participant</h4>

            @if (Model.CanEditParticipants)
            {
                <form method="post" asp-page-handler="Add" class="row g-2 align-items-end">
                    <input type="hidden" asp-for="CompetitionId" />

                    <div class="col-md-8">
                        <label asp-for="SelectedPlayerId" class="form-label">Joueur</label>
                        <select asp-for="SelectedPlayerId" class="form-select">
                            <option value="0">-- Sélectionner un joueur --</option>
                            @foreach (var p in Model.Players)
                            {
                                <option value="@p.Id">@p.FirstName @p.LastName</option>
                            }
                        </select>
                    </div>

                    <div class="col-md-4">
                        <button type="submit" class="btn btn-primary w-100">
                            Ajouter
                        </button>
                    </div>
                </form>
            }
            else
            {
                <div class="alert alert-secondary mb-0">
                    Ajout de participants désactivé.
                </div>
            }
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <h4 class="mb-3">Liste des participants</h4>

            @if (Model.Rounds == null || !Model.Rounds.Any())
            {
                <div class="alert alert-info mb-0">
                    Aucun participant pour cette compétition.
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-striped align-middle">
                        <thead>
                            <tr>
                                <th>Joueur</th>
                                <th style="width: 180px;">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var round in Model.Rounds)
                            {
                                <tr>
                                    <td>
                                        @if (round.Player != null)
                                        {
                                            @($"{round.Player.FirstName} {round.Player.LastName}")
                                        }
                                        else
                                        {
                                            @($"PlayerId={round.PlayerId}")
                                        }
                                    </td>
                                    <td>
                                        @if (Model.CanEditParticipants)
                                        {
                                            <form method="post"
                                                  asp-page-handler="Remove"
                                                  asp-route-roundId="@round.Id"
                                                  class="m-0">
                                                <input type="hidden" asp-for="CompetitionId" />
                                                <button type="submit"
                                                        class="btn btn-sm btn-danger"
                                                        onclick="return confirm('Supprimer ce participant ?');">
                                                    Supprimer
                                                </button>
                                            </form>
                                        }
                                        else
                                        {
                                            <button type="button"
                                                    class="btn btn-sm btn-outline-secondary"
                                                    disabled>
                                                Verrouillé
                                            </button>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

</div>