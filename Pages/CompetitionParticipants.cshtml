@page
@model AFG_Livescoring.Pages.CompetitionParticipantsModel
@{
    ViewData["Title"] = "Participants";
}

<div class="container mt-4">
    <h2 class="mb-2">Participants</h2>

    <div class="mb-3 text-muted">
        Compétition : <strong>@Model.Competition?.Name</strong> (ID @Model.CompetitionId)
        @if (Model.IsTraining)
        {
            <span class="badge bg-info text-dark ms-2">ENTRAÎNEMENT</span>
        }
        else
        {
            <span class="badge bg-dark ms-2">COMPÉTITION</span>
        }
    </div>

    @if (!Model.IsTraining)
    {
        <div class="alert alert-info">
            En compétition, la saisie individuelle est désactivée. Utilise <strong>Score Squad</strong> depuis le Live.
        </div>
    }

    <div class="card mb-4">
        <div class="card-body">
            <form method="post" asp-page-handler="Add" class="row g-3">
                <input type="hidden" asp-for="CompetitionId" />

                <div class="col-md-8">
                    <label class="form-label">Ajouter un joueur</label>
                    <select class="form-select" asp-for="SelectedPlayerId">
                        <option value="0">-- Sélectionner --</option>
                        @foreach (var p in Model.Players)
                        {
                            <option value="@p.Id">@p.LastName @p.FirstName</option>
                        }
                    </select>
                </div>

                <div class="col-md-4 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary w-100">Ajouter</button>
                </div>
            </form>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="text-danger mt-2">
                    @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <div>@err.ErrorMessage</div>
                    }
                </div>
            }
        </div>
    </div>

    <h4>Participants actuels</h4>

    <table class="table table-striped table-bordered align-middle">
        <thead class="table-dark">
            <tr>
                <th style="width:80px;">RoundId</th>
                <th>Joueur</th>
                <th style="width:200px;">Action</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Rounds.Any())
            {
                <tr><td colspan="3" class="text-center text-muted">Aucun participant</td></tr>
            }
            else
            {
                foreach (var r in Model.Rounds)
                {
                    <tr>
                        <td>@r.Id</td>
                        <td>@(r.Player != null ? $"{r.Player.FirstName} {r.Player.LastName}" : $"PlayerId={r.PlayerId}")</td>
                        <td>
                            <div class="d-flex gap-2">
                                @if (Model.IsTraining)
                                {
                                    <a class="btn btn-primary btn-sm"
                                       href="/RoundScore?roundId=@r.Id">
                                        Score
                                    </a>
                                }
                                else
                                {
                                    <button class="btn btn-secondary btn-sm" disabled
                                            title="En compétition : saisie via Score Squad uniquement">
                                        Score
                                    </button>
                                }

                                <form method="post"
                                      asp-page-handler="Remove"
                                      asp-route-roundId="@r.Id">
                                    <button type="submit"
                                            class="btn btn-danger btn-sm">
                                        Retirer
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>

    <a class="btn btn-outline-secondary" href="/Competitions">Retour</a>
</div>