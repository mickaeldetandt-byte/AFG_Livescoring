@page
@model AFG_Livescoring.Pages.MatchPlayScoreModel
@{
    ViewData["Title"] = "Score Match Play";
}

<div class="container mt-4">

    @if (TempData["Message"] != null)
    {
        <div class="alert alert-info">
            @TempData["Message"]
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">
            @TempData["Error"]
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h2 class="mb-1">Score Match Play</h2>
            <div class="text-muted">@Model.CompetitionName</div>
        </div>
        <div>
            <a asp-page="/Leaderboard" asp-route-competitionId="@Model.Match?.CompetitionId" class="btn btn-outline-secondary">
                Retour leaderboard
            </a>
        </div>
    </div>

    @if (Model.Match == null)
    {
        <div class="alert alert-warning">
            Match introuvable.
        </div>
    }
    else
    {
        <div class="card mb-4 shadow-sm">
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-5">
                        <div class="fw-bold">Équipe A</div>
                        <div>@Model.TeamAName</div>
                    </div>
                    <div class="col-md-2 text-center">
                        <div class="fw-bold">Trou</div>
                        <div class="fs-4">@Model.Match.CurrentHole</div>
                    </div>
                    <div class="col-md-5 text-md-end">
                        <div class="fw-bold">Équipe B</div>
                        <div>@Model.TeamBName</div>
                    </div>
                </div>

                <hr />

                <div class="row g-3">
                    <div class="col-md-4">
                        <div><strong>Statut :</strong> @Model.Match.StatusText</div>
                    </div>
                    <div class="col-md-4">
                        <div><strong>Résultat :</strong> @(string.IsNullOrWhiteSpace(Model.Match.ResultText) ? "-" : Model.Match.ResultText)</div>
                    </div>
                    <div class="col-md-4">
                        <div><strong>Terminé :</strong> @(Model.Match.IsFinished ? "Oui" : "Non")</div>
                    </div>
                </div>
            </div>
        </div>

        @if (!Model.Match.IsFinished && Model.Match.CurrentHole <= 18)
        {
            <div class="card mb-4 shadow-sm">
                <div class="card-header">
                    <strong>Saisie du trou @Model.Match.CurrentHole</strong>
                </div>
                <div class="card-body">
                    <form method="post">
                        <input type="hidden" asp-for="matchId" />

                        @if (Model.IsFourballMatchPlay)
                        {
                            <div class="row g-4">
                                <div class="col-md-6">
                                    <div class="border rounded p-3 h-100">
                                        <h5 class="mb-3">Équipe A</h5>

                                        <div class="mb-3">
                                            <label asp-for="TeamAPlayer1Score" class="form-label">@Model.TeamAPlayer1Name</label>
                                            <input asp-for="TeamAPlayer1Score" type="number" min="1" class="form-control form-control-lg" />
                                        </div>

                                        <div class="mb-3">
                                            <label asp-for="TeamAPlayer2Score" class="form-label">@Model.TeamAPlayer2Name</label>
                                            <input asp-for="TeamAPlayer2Score" type="number" min="1" class="form-control form-control-lg" />
                                        </div>
                                    </div>
                                </div>

                                <div class="col-md-6">
                                    <div class="border rounded p-3 h-100">
                                        <h5 class="mb-3">Équipe B</h5>

                                        <div class="mb-3">
                                            <label asp-for="TeamBPlayer1Score" class="form-label">@Model.TeamBPlayer1Name</label>
                                            <input asp-for="TeamBPlayer1Score" type="number" min="1" class="form-control form-control-lg" />
                                        </div>

                                        <div class="mb-3">
                                            <label asp-for="TeamBPlayer2Score" class="form-label">@Model.TeamBPlayer2Name</label>
                                            <input asp-for="TeamBPlayer2Score" type="number" min="1" class="form-control form-control-lg" />
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="row g-4">
                                <div class="col-md-6">
                                    <div class="border rounded p-3 h-100">
                                        <h5 class="mb-3">Équipe A</h5>
                                        <div class="text-muted mb-2">@Model.TeamAName</div>

                                        <label asp-for="TeamAScore" class="form-label">Score équipe A</label>
                                        <input asp-for="TeamAScore" type="number" min="1" class="form-control form-control-lg" />
                                    </div>
                                </div>

                                <div class="col-md-6">
                                    <div class="border rounded p-3 h-100">
                                        <h5 class="mb-3">Équipe B</h5>
                                        <div class="text-muted mb-2">@Model.TeamBName</div>

                                        <label asp-for="TeamBScore" class="form-label">Score équipe B</label>
                                        <input asp-for="TeamBScore" type="number" min="1" class="form-control form-control-lg" />
                                    </div>
                                </div>
                            </div>
                        }

                        <div class="mt-4 d-grid">
                            <button type="submit" class="btn btn-primary btn-lg">
                                Enregistrer le trou @Model.Match.CurrentHole
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        }
        else
        {
            <div class="alert alert-success">
                Ce match est terminé.
            </div>
        }

        <div class="card shadow-sm">
            <div class="card-header">
                <strong>Historique des trous</strong>
            </div>
            <div class="card-body p-0">
                @if (Model.HoleResults == null || Model.HoleResults.Count == 0)
                {
                    <div class="p-3 text-muted">
                        Aucun trou saisi pour l’instant.
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-striped table-hover mb-0 align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>Trou</th>

                                    @if (Model.IsFourballMatchPlay)
                                    {
                                        <th>A1</th>
                                        <th>A2</th>
                                        <th>B1</th>
                                        <th>B2</th>
                                    }

                                    <th>Score A</th>
                                    <th>Score B</th>
                                    <th>Résultat trou</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var hole in Model.HoleResults)
                                {
                                    <tr>
                                        <td><strong>@hole.HoleNumber</strong></td>

                                        @if (Model.IsFourballMatchPlay)
                                        {
                                            <td>@(hole.TeamAPlayer1Score?.ToString() ?? "-")</td>
                                            <td>@(hole.TeamAPlayer2Score?.ToString() ?? "-")</td>
                                            <td>@(hole.TeamBPlayer1Score?.ToString() ?? "-")</td>
                                            <td>@(hole.TeamBPlayer2Score?.ToString() ?? "-")</td>
                                        }

                                        <td>@hole.TeamAScore</td>
                                        <td>@hole.TeamBScore</td>
                                        <td>
                                            @if (hole.IsHalved)
                                            {
                                                <span>Partagé</span>
                                            }
                                            else if (hole.WinnerTeamId == Model.Match.TeamAId)
                                            {
                                                <span>@Model.TeamAName</span>
                                            }
                                            else if (hole.WinnerTeamId == Model.Match.TeamBId)
                                            {
                                                <span>@Model.TeamBName</span>
                                            }
                                            else
                                            {
                                                <span>-</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    }
</div>