@page
@model AFG_Livescoring.Pages.Players.IndexModel
@{
    ViewData["Title"] = "Joueurs";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h2 class="mb-1">Joueurs</h2>
            <div class="text-muted">Gestion des joueurs du club</div>
        </div>

        <div class="d-flex gap-2">
            <a asp-page="/Players/Stats" class="btn btn-outline-primary">
                Voir les stats joueurs
            </a>
            <a asp-page="/Players/Ranking" class="btn btn-outline-dark">
                Classement club
            </a>
        </div>
    </div>

    @if (!ViewContext.ModelState.IsValid)
    {
        <div asp-validation-summary="All" class="alert alert-danger"></div>
    }

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">
            @TempData["Success"]
        </div>
    }

    <div class="card shadow-sm mb-4">
        <div class="card-header">
            <strong>Ajouter un joueur</strong>
        </div>
        <div class="card-body">
            <form method="post" asp-page-handler="Add">
                <div class="row g-3">
                    <div class="col-md-5">
                        <label asp-for="NewPlayer.FirstName" class="form-label">Prénom</label>
                        <input asp-for="NewPlayer.FirstName" class="form-control" />
                    </div>

                    <div class="col-md-5">
                        <label asp-for="NewPlayer.LastName" class="form-label">Nom</label>
                        <input asp-for="NewPlayer.LastName" class="form-control" />
                    </div>

                    <div class="col-md-2 d-grid">
                        <label class="form-label invisible">Ajouter</label>
                        <button type="submit" class="btn btn-primary">
                            Ajouter
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-header">
            <strong>Liste des joueurs</strong>
        </div>
        <div class="card-body p-0">
            @if (Model.Players == null || Model.Players.Count == 0)
            {
                <div class="p-3 text-muted">
                    Aucun joueur enregistré.
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover mb-0 align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Prénom</th>
                                <th>Nom</th>
                                <th style="width: 260px;">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var player in Model.Players)
                            {
                                <tr>
                                    <td>@player.FirstName</td>
                                    <td>@player.LastName</td>
                                    <td>
                                        <div class="d-flex flex-wrap gap-2">
                                            <a asp-page="/Players/Details"
                                               asp-route-id="@player.Id"
                                               class="btn btn-sm btn-outline-primary">
                                                Profil
                                            </a>

                                            <a asp-page="/Players/Stats"
                                               asp-route-playerId="@player.Id"
                                               class="btn btn-sm btn-outline-secondary">
                                                Stats
                                            </a>

                                            <form method="post"
                                                  asp-page-handler="Delete"
                                                  asp-route-id="@player.Id"
                                                  class="d-inline"
                                                  onsubmit="return confirm('Supprimer ce joueur ?');">
                                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                                    Supprimer
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>