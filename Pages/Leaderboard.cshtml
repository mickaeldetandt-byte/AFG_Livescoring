@page
@model AFG_Livescoring.Pages.LeaderboardModel
@{
    ViewData["Title"] = "Leaderboard";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h2 class="mb-1">Leaderboard</h2>

            <div class="text-muted">
                Compétition : <strong>@Model.Competition?.Name</strong>
                @if (Model.IsTraining)
                {
                    <span class="badge bg-info text-dark ms-2">ENTRAÎNEMENT</span>
                }
                else
                {
                    <span class="badge bg-dark ms-2">COMPÉTITION</span>
                }
            </div>

            @if (Model.CourseParTotal > 0)
            {
                <div class="text-muted">
                    Parcours : Par <strong>@Model.CourseParTotal</strong>
                </div>

                @if (Model.LeaderRow != null)
                {
                    <div class="text-muted">
                        Leader :
                        @if (Model.LeaderRow.DiffToPar == 0)
                        {
                            <strong>E</strong>
                        }
                        else if (Model.LeaderRow.DiffToPar > 0)
                        {
                            <strong>+@Model.LeaderRow.DiffToPar</strong>
                        }
                        else
                        {
                            <strong>@Model.LeaderRow.DiffToPar</strong>
                        }
                        après @Model.LeaderRow.HolesPlayed trous
                    </div>
                }
            }
        </div>

        <div class="d-flex gap-2">
            <a class="btn btn-outline-secondary" href="/Competitions">Retour</a>

            <a class="btn btn-primary"
               href="/Leaderboard?competitionId=@Model.CompetitionId">
                Rafraîchir
            </a>

            <a class="btn btn-primary"
               href="/Squads/Manage?competitionId=@Model.CompetitionId">
                Gérer les squads
            </a>
        </div>
    </div>

    <div class="alert alert-info mt-3">
        Astuce : clique sur <strong>Rafraîchir</strong> pour mettre à jour le classement.
    </div>

    @if (Model.SquadProgressById != null && Model.SquadProgressById.Any())
    {
        <div class="card mt-3">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">Suivi des squads</h5>
                    <span class="text-muted small">Basé sur le joueur le plus en retard du squad</span>
                </div>

                <div class="row mt-3">
                    @foreach (var sp in Model.SquadProgressById.Values.OrderBy(x => x.SquadName))
                    {
                        <div class="col-12 col-md-6 col-lg-4 mb-2">
                            <div class="border rounded p-2 d-flex justify-content-between align-items-center">
                                <div>
                                    <div class="fw-bold">@sp.SquadName</div>
                                    <div class="small text-muted">StartHole @sp.StartHole</div>
                                </div>

                                <div class="text-end">
                                    @if (sp.Finished)
                                    {
                                        <span class="badge bg-success">Terminé</span>
                                        <div class="small text-muted">18/18</div>
                                    }
                                    else
                                    {
                                        <span class="badge bg-primary">Trou @sp.CurrentHole</span>
                                        <div class="small text-muted">@sp.MinHolesPlayed/18</div>
                                    }

                                    <a class="btn btn-sm btn-success mt-2"
                                       href="/Squads/Score?competitionId=@Model.CompetitionId&squadId=@sp.SquadId">
                                        Ouvrir Score Squad
                                    </a>
                                </div>
                            </div>
                        </div>
                    }
                </div>

            </div>
        </div>
    }

    <table class="table table-striped table-bordered align-middle mt-3">
        <thead class="table-dark">
            <tr>
                <th style="width:80px;">#</th>
                <th>Joueur</th>
                <th style="width:120px;">Trous</th>
                <th style="width:110px;">Total</th>
                <th style="width:110px;">Par</th>
                <th style="width:110px;">±Par</th>
                <th style="width:110px;">Écart</th>
                <th style="width:120px;">Moy.</th>
                <th style="width:140px;">Squad</th>
                <th style="width:120px;">Trou squad</th>
                <th style="width:140px;">Score Joueur</th>
                <th style="width:140px;">Score Squad</th>
            </tr>
        </thead>
        <tbody>
            @{
                var rank = 1;
            }

            @foreach (var row in Model.Rows)
            {
                var isLeader = rank == 1 && row.TotalStrokes > 0;

                <tr class="@(isLeader ? "table-success fw-bold" : "")">
                    <td>@rank</td>

                    <td>
                        <a href="/RoundCard?roundId=@row.RoundId" class="text-decoration-none">
                            @row.PlayerName
                        </a>
                    </td>

                    <td>@row.HolesPlayed / 18</td>

                    <td>@(row.TotalStrokes == 0 ? "-" : row.TotalStrokes)</td>
                    <td>@(row.TotalStrokes == 0 ? "-" : row.TotalPar)</td>

                    <td>
                        @if (row.TotalStrokes == 0)
                        {
                            @("-")
                        }
                        else if (row.DiffToPar == 0)
                        {
                            @("E")
                        }
                        else if (row.DiffToPar > 0)
                        {
                            @("+" + row.DiffToPar)
                        }
                        else
                        {
                            @row.DiffToPar
                        }
                    </td>

                    <td>
                        @if (row.TotalStrokes == 0)
                        {
                            @("-")
                        }
                        else if (row.Difference == 0)
                        {
                            @("E")
                        }
                        else
                        {
                            @("+" + row.Difference)
                        }
                    </td>

                    <td>@(row.HolesPlayed == 0 ? "-" : row.Average.ToString("0.00"))</td>

                    <td>
                        @if (!string.IsNullOrWhiteSpace(row.SquadName))
                        {
                            <div class="fw-semibold">@row.SquadName</div>
                            @if (row.SquadStartHole.HasValue)
                            {
                                <div class="small text-muted">SH @row.SquadStartHole</div>
                            }
                        }
                        else
                        {
                            <span class="text-muted">-</span>
                        }
                    </td>

                    <td>
                        @if (row.SquadId.HasValue && Model.SquadProgressById.TryGetValue(row.SquadId.Value, out var prog))
                        {
                            if (prog.Finished)
                            {
                                <span class="badge bg-success">Terminé</span>
                            }
                            else
                            {
                                <span class="badge bg-primary">Trou @prog.CurrentHole</span>
                                <div class="small text-muted">@prog.MinHolesPlayed / 18</div>
                            }
                        }
                        else
                        {
                            <span class="text-muted">-</span>
                        }
                    </td>

                    <td>
                        @if (Model.IsTraining)
                        {
                            <a class="btn btn-sm btn-primary"
                               href="/RoundScore?roundId=@row.RoundId">
                                Score Joueur
                            </a>
                        }
                        else
                        {
                            <button class="btn btn-sm btn-secondary" disabled
                                    title="En compétition : saisie via Score Squad uniquement">
                                Score Joueur
                            </button>
                        }
                    </td>

                    <td>
                        @if (row.SquadId.HasValue)
                        {
                            <a class="btn btn-sm btn-success"
                               href="/Squads/Score?competitionId=@Model.CompetitionId&squadId=@row.SquadId">
                                Score Squad
                            </a>
                        }
                        else
                        {
                            <button class="btn btn-sm btn-secondary" disabled
                                    title="Aucun squad. Va dans Gérer les squads pour affecter le joueur.">
                                Score Squad
                            </button>
                        }
                    </td>
                </tr>

                rank++;
            }
        </tbody>
    </table>

</div>

<script>
    setTimeout(function () {
        window.location.reload();
    }, 30000);
</script>