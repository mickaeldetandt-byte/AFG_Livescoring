@page
@model AFG_Livescoring.Pages.Courses.HolesModel
@{
    ViewData["Title"] = "Trous / Par";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h2 class="mb-0">Trous / Par</h2>
            <div class="text-muted">Parcours : <strong>@Model.Course?.Name</strong></div>
        </div>
        <a class="btn btn-outline-secondary" href="/Courses/Index">Retour</a>
    </div>

    <form method="post" asp-page-handler="Save" class="mt-3">
        <input type="hidden" asp-for="CourseId" />

        <table class="table table-bordered align-middle">
            <thead class="table-dark">
                <tr>
                    <th style="width:120px;">Trou</th>
                    <th style="width:200px;">Par</th>
                </tr>
            </thead>
            <tbody>
                @for (int i = 0; i < 18; i++)
                {
                    <tr>
                        <td>@(i + 1)</td>
                        <td>
                            <select class="form-select" name="Pars[@i]">
                                @for (int p = 2; p <= 6; p++)
                                {
                                    <option value="@p" selected="@(Model.Pars[i] == p)">
                                        @p
                                    </option>
                                }
                            </select>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <button class="btn btn-primary w-100" type="submit">Enregistrer</button>
    </form>
</div>