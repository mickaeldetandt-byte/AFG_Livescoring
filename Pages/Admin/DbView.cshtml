@page
@model AFG_Livescoring.Pages.Admin.DbViewModel
@{
    ViewData["Title"] = "Vue base de données";
}

<div class="container mt-4">

    <h2 class="mb-3">Vue base de données (SQLite)</h2>

    <div class="alert alert-secondary">
        <div><strong>DB utilisée :</strong> @Model.DbPath</div>
        <div class="mt-2"><strong>Tables :</strong> @string.Join(", ", Model.Tables)</div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card">
                <div class="card-body">
                    <div class="text-muted">Players</div>
                    <div class="fs-3 fw-bold">@Model.PlayersCount</div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card">
                <div class="card-body">
                    <div class="text-muted">Competitions</div>
                    <div class="fs-3 fw-bold">@Model.CompetitionsCount</div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card">
                <div class="card-body">
                    <div class="text-muted">Rounds</div>
                    <div class="fs-3 fw-bold">@Model.RoundsCount</div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card">
                <div class="card-body">
                    <div class="text-muted">Scores</div>
                    <div class="fs-3 fw-bold">@Model.ScoresCount</div>
                </div>
            </div>
        </div>
    </div>


    <h4 class="mt-3">Players</h4>
    <table class="table table-striped table-bordered align-middle">
        <thead class="table-dark">
            <tr>
                <th style="width:80px;">Id</th>
                <th>Prénom</th>
                <th>Nom</th>
                <th style="width:120px;">Actif</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Players.Any())
            {
                <tr><td colspan="4" class="text-center text-muted">Aucun joueur</td></tr>
            }
            else
            {
                foreach (var p in Model.Players)
                {
                    <tr>
                        <td>@p.Id</td>
                        <td>@p.FirstName</td>
                        <td>@p.LastName</td>
                        <td>@(p.IsActive ? "Oui" : "Non")</td>
                    </tr>
                }
            }
        </tbody>
    </table>

    <h4 class="mt-4">Competitions</h4>
    <table class="table table-striped table-bordered align-middle">
        <thead class="table-dark">
            <tr>
                <th style="width:80px;">Id</th>
                <th>Nom</th>
                <th style="width:160px;">Date</th>
                <th style="width:120px;">Active</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Competitions.Any())
            {
                <tr><td colspan="4" class="text-center text-muted">Aucune compétition</td></tr>
            }
            else
            {
                foreach (var c in Model.Competitions)
                {
                    <tr>
                        <td>@c.Id</td>
                        <td>@c.Name</td>
                        <td>@c.Date.ToString("dd/MM/yyyy")</td>
                        <td>@(c.IsActive ? "Oui" : "Non")</td>
                    </tr>
                }
            }
        </tbody>
    </table>

    <div class="row g-3 mb-4">
        <!-- ... tes cartes existantes ... -->

        <div class="col-md-3">
            <div class="card">
                <div class="card-body">
                    <div class="text-muted">Squads</div>
                    <div class="fs-3 fw-bold">@Model.SquadsCount</div>
                </div>
            </div>
        </div>
    </div>

    <h4 class="mt-4">Squads</h4>
    <table class="table table-striped table-bordered align-middle">
        <thead class="table-dark">
            <tr>
                <th style="width:80px;">Id</th>
                <th>Compétition</th>
                <th style="width:120px;">Nom</th>
                <th style="width:120px;">StartHole</th>
                <th style="width:160px;">StartTime</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Squads.Any())
            {
                <tr><td colspan="5" class="text-center text-muted">Aucun squad</td></tr>
            }
            else
            {
                foreach (var s in Model.Squads)
                {
                    <tr>
                        <td>@s.Id</td>
                        <td>@(s.Competition?.Name ?? $"CompetitionId={s.CompetitionId}")</td>
                        <td>@s.Name</td>
                        <td>@s.StartHole</td>
                        <td>@(s.StartTime?.ToString("dd/MM/yyyy HH:mm") ?? "-")</td>
                    </tr>
                }
            }
        </tbody>
    </table>

    <h4 class="mt-4">Rounds</h4>
    <table class="table table-striped table-bordered align-middle">
        <thead class="table-dark">
            <tr>
                <th style="width:80px;">Id</th>
                <th>Joueur</th>
                <th>Compétition</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Rounds.Any())
            {
                <tr><td colspan="3" class="text-center text-muted">Aucun round</td></tr>
            }
            else
            {
                foreach (var r in Model.Rounds)
                {
                    <tr>
                        <td>@r.Id</td>
                        <td>@(r.Player != null ? $"{r.Player.FirstName} {r.Player.LastName}" : $"PlayerId={r.PlayerId}")</td>
                        <td>@(r.Competition != null ? r.Competition.Name : $"CompetitionId={r.CompetitionId}")</td>
                    </tr>
                }
            }
        </tbody>
    </table>

    <h4 class="mt-4">Scores (dernier 200)</h4>
    <table class="table table-striped table-bordered align-middle">
        <thead class="table-dark">
            <tr>
                <th style="width:80px;">Id</th>
                <th>Compétition</th>
                <th>Joueur</th>
                <th style="width:100px;">Trou</th>
                <th style="width:100px;">Coups</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Scores.Any())
            {
                <tr><td colspan="5" class="text-center text-muted">Aucun score</td></tr>
            }
            else
            {
                foreach (var s in Model.Scores)
                {
                    <tr>
                        <td>@s.Id</td>
                        <td>@(s.Round?.Competition?.Name ?? $"CompetitionId={s.Round?.CompetitionId}")</td>
                        <td>@(s.Round?.Player != null ? $"{s.Round.Player.FirstName} {s.Round.Player.LastName}" : $"PlayerId={s.Round?.PlayerId}")</td>
                        <td>@s.HoleNumber</td>
                        <td>@s.Strokes</td>
                    </tr>
                }
            }
        </tbody>
    </table>


</div>