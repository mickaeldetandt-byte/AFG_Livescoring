@page
@model PlayersModel
@{
    ViewData["Title"] = "Joueurs";
}

<div class="container mt-4">

    <h2 class="mb-4">Liste des joueurs</h2>

    <!-- Formulaire ajout -->
    <div class="card mb-4">
        <div class="card-body">
            <form method="post" asp-page-handler="Add" class="row g-3">
                <div class="col-md-5">
                    <label class="form-label">Prénom</label>
                    <input asp-for="NewPlayer.FirstName" class="form-control" />
                </div>

                <div class="col-md-5">
                    <label class="form-label">Nom</label>
                    <input asp-for="NewPlayer.LastName" class="form-control" />
                </div>

                <div class="col-md-2 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary w-100">
                        Ajouter
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Tableau joueurs -->
    <table class="table table-striped table-bordered">
        <thead class="table-dark">
            <tr>
                <th>Id</th>
                <th>Prénom</th>
                <th>Nom</th>
                <th style="width:120px;">Action</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var p in Model.Players)
            {
                <tr>
                    <td>@p.Id</td>
                    <td>@p.FirstName</td>
                    <td>@p.LastName</td>
                    <td>
                        <form method="post" asp-page-handler="Delete" asp-route-id="@p.Id">
                            <button type="submit" class="btn btn-danger btn-sm">
                                Supprimer
                            </button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>

</div>