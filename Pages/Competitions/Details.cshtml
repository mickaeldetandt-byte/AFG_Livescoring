@page "{id:int}"
@using AFG_Livescoring.Models
@model AFG_Livescoring.Pages.Competitions.DetailsModel
@{
    ViewData["Title"] = "Détail compétition";
}

<div class="container mt-4">

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">
            @TempData["Error"]
        </div>
    }

    @if (TempData["Info"] != null)
    {
        <div class="alert alert-info">
            @TempData["Info"]
        </div>
    }

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">
            @TempData["SuccessMessage"]
        </div>
    }

    @if (Model.Competition == null)
    {
        <div class="alert alert-warning">
            Compétition introuvable.
        </div>
    }
    else
    {
        <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-4">
            <div>
                <h2 class="mb-1">@Model.Competition.Name</h2>
                <div class="text-muted">
                    @Model.Competition.Date.ToString("dd/MM/yyyy")
                    @if (Model.Course != null)
                    {
                        <span>• @Model.Course.Name</span>
                    }
                </div>
            </div>

            <div class="d-flex flex-wrap gap-2">
                <a asp-page="/Competitions" class="btn btn-outline-secondary">Retour</a>
                <a asp-page="/Competitions/ResultsDetails" asp-route-competitionId="@Model.Competition.Id" class="btn btn-outline-dark">Résultats</a>
                <a asp-page="/Leaderboard" asp-route-competitionId="@Model.Competition.Id" class="btn btn-outline-primary">Leaderboard</a>
                <a asp-page="/Display" asp-route-competitionId="@Model.Competition.Id" class="btn btn-outline-info">Club House</a>
                <a asp-page="/CompetitionParticipants" asp-route-competitionId="@Model.Competition.Id" class="btn btn-outline-success">Participants</a>
            </div>
        </div>

        <div class="row g-3 mb-4">
            <div class="col-md-6 col-xl-3">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">
                        <div class="text-muted small">Statut</div>
                        <div class="fw-bold fs-5">@Model.FormatStatus(Model.Competition.Status)</div>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-xl-3">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">
                        <div class="text-muted small">Visibilité</div>
                        <div class="fw-bold fs-5">@Model.FormatVisibility(Model.Competition.Visibility)</div>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-xl-3">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">
                        <div class="text-muted small">Participants</div>
                        <div class="fw-bold fs-5">@Model.PlayerCount</div>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-xl-3">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">
                        <div class="text-muted small">Squads</div>
                        <div class="fw-bold fs-5">@Model.SquadCount</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-3 mb-4">
            <div class="col-md-6 col-xl-3">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">
                        <div class="text-muted small">Mode</div>
                        <div class="fw-bold">@Model.Competition.Mode</div>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-xl-3">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">
                        <div class="text-muted small">Format</div>
                        <div class="fw-bold">@Model.Competition.CompetitionType</div>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-xl-3">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">
                        <div class="text-muted small">Scoring démarré</div>
                        <div class="fw-bold">@(Model.HasStarted ? "Oui" : "Non")</div>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-xl-3">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">
                        <div class="text-muted small">Cartes complètes</div>
                        <div class="fw-bold">@Model.CompletedRounds / @Model.PlayerCount</div>
                    </div>
                </div>
            </div>
        </div>

        @if (Model.AutoFinishedByScores && Model.Competition.Status != CompetitionStatus.Finished)
        {
            <div class="alert alert-warning">
                Tous les rounds individuels semblent terminés d’après les scores, mais la compétition n’a pas encore été clôturée officiellement.
            </div>
        }

        @if (Model.Competition.Status == CompetitionStatus.Draft && Model.HasStarted)
        {
            <div class="alert alert-warning">
                Du scoring existe déjà alors que le statut est encore "Brouillon". Il faut régulariser l’état de cette compétition.
            </div>
        }

        <div class="card shadow-sm mb-4">
            <div class="card-header">
                <strong>Actions organisateur</strong>
            </div>
            <div class="card-body d-flex flex-wrap gap-2">
                @if (Model.CanStart)
                {
                    <form method="post" asp-page-handler="Start" asp-route-id="@Model.Competition.Id">
                        <button type="submit" class="btn btn-success">
                            Démarrer la compétition
                        </button>
                    </form>
                }

                @if (Model.CanFinish)
                {
                    <form method="post" asp-page-handler="Finish" asp-route-id="@Model.Competition.Id"
                          onsubmit="return confirm('Confirmer la clôture de cette compétition ?');">
                        <button type="submit" class="btn btn-danger">
                            Terminer la compétition
                        </button>
                    </form>
                }

                @if (Model.Competition.Status == CompetitionStatus.Finished)
                {
                    <span class="badge bg-dark p-2 fs-6">Compétition terminée</span>
                }
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="card-header">
                <strong>Navigation rapide</strong>
            </div>
            <div class="card-body">
                <div class="list-group">
                    <a asp-page="/CompetitionParticipants" asp-route-competitionId="@Model.Competition.Id" class="list-group-item list-group-item-action">
                        Gérer les participants
                    </a>
                    <a asp-page="/Leaderboard" asp-route-competitionId="@Model.Competition.Id" class="list-group-item list-group-item-action">
                        Voir le leaderboard
                    </a>
                    <a asp-page="/Display" asp-route-competitionId="@Model.Competition.Id" class="list-group-item list-group-item-action">
                        Voir le Club House / Display
                    </a>
                    <a asp-page="/Competitions/ResultsDetails" asp-route-competitionId="@Model.Competition.Id" class="list-group-item list-group-item-action">
                        Voir les résultats détaillés
                    </a>
                </div>
            </div>
        </div>
    }
</div>