@page
@model AFG_Livescoring.Pages.Competitions.DetailsModel
@{
    ViewData["Title"] = "Détails compétition";
}

<style>
    .details-page {
        max-width: 1100px;
        margin: 0 auto;
    }

    .action-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
        gap: 12px;
    }

    .action-card {
        border-radius: 16px;
        border: 1px solid #dee2e6;
        background: #fff;
        padding: 14px;
        text-align: center;
        text-decoration: none;
        color: inherit;
        font-weight: 700;
        box-shadow: 0 4px 12px rgba(0,0,0,.04);
    }

    .stat-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 12px;
    }

    .stat-card {
        border-radius: 16px;
        background: #fff;
        border: 1px solid #dee2e6;
        padding: 14px;
        box-shadow: 0 4px 12px rgba(0,0,0,.04);
    }

    .big-btn {
        min-height: 52px;
        border-radius: 14px;
        font-weight: 700;
    }
</style>

<div class="container mt-3 mb-4 details-page">

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    @if (TempData["Info"] != null)
    {
        <div class="alert alert-info">@TempData["Info"]</div>
    }

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }

    <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
        <div>
            <h2 class="mb-1">@Model.Competition?.Name</h2>
            <div class="text-muted">
                Statut : <strong>@Model.FormatStatus(Model.Competition!.Status)</strong>
            </div>
            <div class="text-muted">
                Mode : <strong>@(Model.IsTraining ? "Entraînement" : "Compétition")</strong>
            </div>
            <div class="text-muted">
                Visibilité : <strong>@Model.FormatVisibility(Model.Competition.Visibility)</strong>
            </div>
        </div>

        <a class="btn btn-outline-secondary big-btn" href="/Competitions">
            Retour compétitions
        </a>
    </div>

    <div class="action-grid mb-4">
        @if (Model.ShowLeaderboardButton)
        {
            <a class="action-card" href="/Leaderboard?competitionId=@Model.Id">
                Leaderboard / Live
            </a>
        }

        @if (Model.ShowSquadsButton)
        {
            <a class="action-card" href="/Squads/Manage?competitionId=@Model.Id">
                Gérer les squads
            </a>
        }

        @if (Model.ShowParticipantsButton)
        {
            <a class="action-card" href="/CompetitionParticipants?competitionId=@Model.Id">
                Participants
            </a>
        }

        @if (Model.ShowResultsButton)
        {
            <a class="action-card" href="/Competitions/Results?competitionId=@Model.Id">
                Résultats
            </a>
        }
    </div>

    <div class="stat-grid mb-4">
        <div class="stat-card">
            <div class="small text-muted">Participants</div>
            <div class="fs-3 fw-bold">@Model.PlayerCount</div>
        </div>

        <div class="stat-card">
            <div class="small text-muted">Squads</div>
            <div class="fs-3 fw-bold">@Model.SquadCount</div>
        </div>

        <div class="stat-card">
            <div class="small text-muted">Compétition démarrée</div>
            <div class="fs-3 fw-bold">@(Model.HasStarted ? "Oui" : "Non")</div>
        </div>

        <div class="stat-card">
            <div class="small text-muted">Cartes complètes</div>
            <div class="fs-3 fw-bold">@Model.CompletedRounds</div>
        </div>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-header fw-bold">Informations</div>
        <div class="card-body">
            <div class="row gy-3">
                <div class="col-md-6">
                    <div><strong>Parcours :</strong> @(Model.Course?.Name ?? "-")</div>
                    <div><strong>Club :</strong> @(Model.Competition?.Club?.Name ?? "-")</div>
                    <div><strong>Date :</strong> @(Model.Competition?.Date.ToString("dd/MM/yyyy") ?? "-")</div>
                </div>
                <div class="col-md-6">
                    <div><strong>Créée par :</strong> @(Model.Competition?.CreatedByUser?.Email ?? "-")</div>
                    <div><strong>Auto fin par scores :</strong> @(Model.AutoFinishedByScores ? "Oui" : "Non")</div>
                    <div><strong>ID :</strong> @Model.Id</div>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-header fw-bold">Actions organisateur</div>
        <div class="card-body">
            <div class="d-grid gap-2 d-md-flex">
                @if (Model.CanStart)
                {
                    <form method="post" asp-page-handler="Start" class="d-grid">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button type="submit" class="btn btn-success big-btn">
                            Démarrer la compétition
                        </button>
                    </form>
                }

                @if (Model.CanFinish)
                {
                    <form method="post" asp-page-handler="Finish" class="d-grid">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button type="submit" class="btn btn-danger big-btn">
                            Terminer la compétition
                        </button>
                    </form>
                }

                @if (Model.ShowLeaderboardButton)
                {
                    <a class="btn btn-outline-primary big-btn" href="/Leaderboard?competitionId=@Model.Id">
                        Ouvrir le live
                    </a>
                }

                @if (Model.ShowSquadsButton)
                {
                    <a class="btn btn-outline-primary big-btn" href="/Squads/Manage?competitionId=@Model.Id">
                        Ouvrir les squads
                    </a>
                }
            </div>
        </div>
    </div>
</div>