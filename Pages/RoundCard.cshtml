@page
@model AFG_Livescoring.Pages.RoundCardModel
@{
    ViewData["Title"] = "Carte joueur";
}

<div class="container mt-4">

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-warning">
            @TempData["Error"]
        </div>
    }

    @if (TempData["Info"] != null)
    {
        <div class="alert alert-info">
            @TempData["Info"]
        </div>
    }

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h3 class="mb-1">Carte joueur</h3>
            <div class="text-muted">
                Joueur :
                <strong>@(Model.Round?.Player?.FirstName) @(Model.Round?.Player?.LastName)</strong>
                — Compétition :
                <strong>@Model.Competition?.Name</strong>

                @if (Model.Competition != null)
                {
                    if (Model.Competition.ScoringMode == AFG_Livescoring.Models.ScoringMode.SquadOnly)
                    {
                        <span class="badge bg-dark ms-2">COMPÉTITION</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary ms-2">ENTRAÎNEMENT</span>
                    }
                }

                @if (Model.Round?.SquadId != null && Model.Squad != null)
                {
                    <span>
                        — Squad : <strong>@Model.Squad.Name</strong>
                    </span>
                }
            </div>
        </div>

        <div class="d-flex gap-2 flex-wrap">
            @if (Model.Round?.SquadId != null)
            {
                <a class="btn btn-success"
                   href="/Squads/Score?competitionId=@Model.Round.CompetitionId&squadId=@Model.Round.SquadId">
                    Score Squad
                </a>
            }

            @if (Model.Competition?.ScoringMode == AFG_Livescoring.Models.ScoringMode.IndividualAllowed && Model.Round != null)
            {
                <a class="btn btn-primary" href="/RoundScore?roundId=@Model.Round.Id">
                    Score Joueur
                </a>
            }
            else
            {
                <button class="btn btn-secondary" disabled
                        title="En compétition : saisie via Score Squad uniquement">
                    Score Joueur
                </button>
            }

            <a class="btn btn-outline-secondary"
               href="/Leaderboard?competitionId=@Model.Round?.CompetitionId">
                Retour Live
            </a>
        </div>
    </div>

    <!-- Résumé -->
    <div class="card mb-3">
        <div class="card-body d-flex justify-content-between align-items-center">
            <div>
                <div class="fw-bold">
                    Trous joués : @Model.HolesPlayed / 18
                </div>
                <div class="text-muted small">
                    Parcours Par : <strong>@Model.CourseParTotal</strong>
                </div>
            </div>

            <div class="text-end">
                <div class="fw-bold fs-4">
                    Total : @(Model.TotalStrokes == 0 ? "-" : Model.TotalStrokes)
                </div>
                <div class="text-muted">
                    ±Par :
                    @if (Model.HolesPlayed == 0)
                    {
                        <strong>-</strong>
                    }
                    else if (Model.DiffToPar == 0)
                    {
                        <strong>E</strong>
                    }
                    else if (Model.DiffToPar > 0)
                    {
                        <strong>+@Model.DiffToPar</strong>
                    }
                    else
                    {
                        <strong>@Model.DiffToPar</strong>
                    }
                </div>
            </div>
        </div>
    </div>

    @if (Model.Round != null && Model.Round.IsLocked)
    {
        <div class="mt-2">
            <span class="badge bg-dark">CARTE VERROUILLÉE</span>
        </div>
    }

    <!-- Tableau trous -->
    <table class="table table-striped table-bordered align-middle mt-3">
        <thead class="table-dark">
            <tr>
                <th style="width:90px;">Trou</th>
                <th style="width:90px;">Par</th>
                <th style="width:120px;">Score</th>
                <th style="width:120px;">±Par</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var h in Model.Holes)
            {
                <tr>
                    <td class="fw-bold">@h.HoleNumber</td>
                    <td>@(h.Par?.ToString() ?? "-")</td>
                    <td>@(h.Strokes == 0 ? "-" : h.Strokes)</td>
                    <td>
                        @if (h.Strokes == 0 || h.DiffToPar == null)
                        {
                            @("-")
                        }
                        else if (h.DiffToPar == 0)
                        {
                            @("E")
                        }
                        else if (h.DiffToPar > 0)
                        {
                            @("+" + h.DiffToPar)
                        }
                        else
                        {
                            @h.DiffToPar
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>

</div>