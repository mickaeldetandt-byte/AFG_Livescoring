@page
@model AFG_Livescoring.Pages.RoundCardModel
@{
    ViewData["Title"] = "Carte joueur";
}

<style>
    .summary-card,
    .stats-card,
    .split-card {
        border-radius: 16px;
    }

    .stat-number {
        font-size: 1.3rem;
        font-weight: 800;
    }

    .hole-result-eagle {
        color: #0d6efd;
        font-weight: 700;
    }

    .hole-result-birdie {
        color: #198754;
        font-weight: 700;
    }

    .hole-result-par {
        color: #6c757d;
        font-weight: 700;
    }

    .hole-result-bogey {
        color: #fd7e14;
        font-weight: 700;
    }

    .hole-result-double {
        color: #dc3545;
        font-weight: 700;
    }

    .score-under {
        color: #198754;
        font-weight: 700;
    }

    .score-even {
        color: #6c757d;
        font-weight: 700;
    }

    .score-over {
        color: #dc3545;
        font-weight: 700;
    }

    .mini-muted {
        font-size: 0.85rem;
        color: #6c757d;
    }
</style>

<div class="container mt-4">

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-warning">
            @TempData["Error"]
        </div>
    }

    @if (TempData["Info"] != null)
    {
        <div class="alert alert-info">
            @TempData["Info"]
        </div>
    }

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
        <div>
            <h3 class="mb-1">Carte joueur</h3>
            <div class="text-muted">
                Joueur :
                <strong>@(Model.Round?.Player?.FirstName) @(Model.Round?.Player?.LastName)</strong>
                — Compétition :
                <strong>@Model.Competition?.Name</strong>

                @if (Model.Competition != null)
                {
                    if (Model.IsCompetition)
                    {
                        <span class="badge bg-dark ms-2">COMPÉTITION</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary ms-2">ENTRAÎNEMENT</span>
                    }
                }

                @if (Model.Round?.SquadId != null && Model.Squad != null)
                {
                    <span>
                        — Squad : <strong>@Model.Squad.Name</strong>
                    </span>
                }
            </div>
        </div>

        <div class="d-flex gap-2 flex-wrap">
            @if (Model.Round?.SquadId != null)
            {
                <a class="btn btn-success"
                   href="/Squads/Score?competitionId=@Model.Round.CompetitionId&squadId=@Model.Round.SquadId">
                    Score Squad
                </a>
            }

            @if (Model.IsTraining && Model.Round != null)
            {
                <a class="btn btn-primary" href="/RoundScore?roundId=@Model.Round.Id">
                    Score Joueur
                </a>
            }
            else
            {
                <button class="btn btn-secondary" disabled
                        title="En compétition : saisie via Score Squad uniquement">
                    Score Joueur
                </button>
            }

            <a class="btn btn-outline-secondary"
               href="/Leaderboard?competitionId=@Model.Round?.CompetitionId">
                Retour Live
            </a>
        </div>
    </div>

    @if (Model.Round != null && Model.Round.IsLocked)
    {
        <div class="mb-3">
            <span class="badge bg-dark">CARTE VERROUILLÉE</span>
        </div>
    }

    <!-- Résumé principal -->
    <div class="card mb-3 shadow-sm summary-card">
        <div class="card-body">
            <div class="row g-3 align-items-center">
                <div class="col-md-3">
                    <div class="fw-bold">Trous joués</div>
                    <div class="stat-number">@Model.HolesPlayed / 18</div>
                    <div class="mini-muted">Parcours Par : @Model.CourseParTotal</div>
                </div>

                <div class="col-md-3">
                    <div class="fw-bold">Total</div>
                    <div class="stat-number">@(Model.TotalStrokes == 0 ? "-" : Model.TotalStrokes)</div>
                </div>

                <div class="col-md-3">
                    <div class="fw-bold">±Par</div>
                    <div class="stat-number @Model.GetScoreCssClass(Model.DiffToPar, Model.HolesPlayed > 0)">
                        @Model.FormatDiffToPar(Model.DiffToPar, Model.HolesPlayed > 0)
                    </div>
                </div>

                <div class="col-md-3">
                    <div class="fw-bold">Position</div>
                    <div class="stat-number">
                        @(Model.Position.HasValue ? $"#{Model.Position.Value}" : "-")
                    </div>
                    <div class="mini-muted">
                        @if (Model.PlayerCount > 0)
                        {
                            @:sur @Model.PlayerCount joueurs
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Aller / Retour -->
    <div class="row g-3 mb-3">
        <div class="col-md-6">
            <div class="card shadow-sm split-card">
                <div class="card-body">
                    <h5 class="mb-2">Aller (1–9)</h5>
                    <div class="d-flex justify-content-between">
                        <span>Score</span>
                        <strong>@(Model.OutTotalStrokes == 0 ? "-" : Model.OutTotalStrokes)</strong>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span>Par joué</span>
                        <strong>@(Model.OutPlayedHoles == 0 ? "-" : Model.OutTotalPar)</strong>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span>±Par</span>
                        <strong class="@Model.GetScoreCssClass(Model.OutDiffToPar, Model.OutPlayedHoles > 0)">
                            @Model.FormatDiffToPar(Model.OutDiffToPar, Model.OutPlayedHoles > 0)
                        </strong>
                    </div>
                    <div class="mini-muted mt-2">@Model.OutPlayedHoles / 9 trous joués</div>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card shadow-sm split-card">
                <div class="card-body">
                    <h5 class="mb-2">Retour (10–18)</h5>
                    <div class="d-flex justify-content-between">
                        <span>Score</span>
                        <strong>@(Model.InTotalStrokes == 0 ? "-" : Model.InTotalStrokes)</strong>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span>Par joué</span>
                        <strong>@(Model.InPlayedHoles == 0 ? "-" : Model.InTotalPar)</strong>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span>±Par</span>
                        <strong class="@Model.GetScoreCssClass(Model.InDiffToPar, Model.InPlayedHoles > 0)">
                            @Model.FormatDiffToPar(Model.InDiffToPar, Model.InPlayedHoles > 0)
                        </strong>
                    </div>
                    <div class="mini-muted mt-2">@Model.InPlayedHoles / 9 trous joués</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Statistiques -->
    <div class="card mb-3 shadow-sm stats-card">
        <div class="card-body">
            <h5 class="mb-3">Statistiques</h5>

            <div class="row g-3 text-center">
                <div class="col-6 col-md-2">
                    <div class="border rounded p-2">
                        <div class="mini-muted">Eagle+</div>
                        <div class="stat-number text-primary">@Model.EaglesOrBetter</div>
                    </div>
                </div>

                <div class="col-6 col-md-2">
                    <div class="border rounded p-2">
                        <div class="mini-muted">Birdie</div>
                        <div class="stat-number text-success">@Model.Birdies</div>
                    </div>
                </div>

                <div class="col-6 col-md-2">
                    <div class="border rounded p-2">
                        <div class="mini-muted">Par</div>
                        <div class="stat-number text-secondary">@Model.Pars</div>
                    </div>
                </div>

                <div class="col-6 col-md-2">
                    <div class="border rounded p-2">
                        <div class="mini-muted">Bogey</div>
                        <div class="stat-number text-warning">@Model.Bogeys</div>
                    </div>
                </div>

                <div class="col-6 col-md-2">
                    <div class="border rounded p-2">
                        <div class="mini-muted">Double+</div>
                        <div class="stat-number text-danger">@Model.DoubleBogeyOrWorse</div>
                    </div>
                </div>

                <div class="col-6 col-md-2">
                    <div class="border rounded p-2">
                        <div class="mini-muted">Moyenne</div>
                        <div class="stat-number">
                            @(Model.HolesPlayed == 0 ? "-" : Model.Average.ToString("0.00"))
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Tableau trous -->
    <div class="table-responsive">
        <table class="table table-striped table-bordered align-middle mt-3">
            <thead class="table-dark">
                <tr>
                    <th style="width:90px;">Trou</th>
                    <th style="width:90px;">Par</th>
                    <th style="width:120px;">Score</th>
                    <th style="width:120px;">±Par</th>
                    <th style="width:160px;">Résultat</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var h in Model.Holes)
                {
                    <tr>
                        <td class="fw-bold">@h.HoleNumber</td>
                        <td>@(h.Par?.ToString() ?? "-")</td>
                        <td>@(h.Strokes == 0 ? "-" : h.Strokes)</td>

                        <td class="@Model.GetScoreCssClass(h.DiffToPar ?? 0, h.Strokes > 0)">
                            @Model.FormatDiffToPar(h.DiffToPar ?? 0, h.Strokes > 0)
                        </td>

                        <td class="@Model.GetHoleResultCssClass(h.ResultLabel)">
                            @(string.IsNullOrWhiteSpace(h.ResultLabel) ? "-" : h.ResultLabel)
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

</div>