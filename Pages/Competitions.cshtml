@page
@model AFG_Livescoring.Pages.CompetitionsModel
@{
    ViewData["Title"] = "Compétitions";
}

<div class="container mt-4">

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-warning mt-3">
            @TempData["Error"]
        </div>
    }

    <!-- Titre + bouton Parcours -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0">Compétitions</h2>
        <a class="btn btn-outline-primary" href="/Courses/Index">Parcours</a>
    </div>

    <!-- Form ajout -->
    <div class="card mb-4">
        <div class="card-body">
            <form method="post" asp-page-handler="Add" class="row g-3">

                <div class="col-md-6">
                    <label class="form-label">Nom</label>
                    <input asp-for="NewCompetition.Name" class="form-control" />
                </div>

                <div class="col-md-3">
                    <label class="form-label">Parcours</label>
                    <select asp-for="NewCompetition.CourseId" class="form-select">
                        <option value="">-- Sélectionner --</option>
                        @foreach (var course in Model.Courses)
                        {
                            <option value="@course.Id">@course.Name</option>
                        }
                    </select>
                </div>

                <div class="col-md-3">
                    <label class="form-label">Date</label>
                    <input asp-for="NewCompetition.Date" type="date" class="form-control" />
                </div>

                <!-- ✅ NEW : Mode -->
                <div class="col-md-4">
                    <label class="form-label">Mode</label>
                    <select asp-for="NewCompetition.ScoringMode" class="form-select">
                        <option value="0">Compétition (scoring par squad)</option>
                        <option value="1">Entraînement (scoring individuel)</option>
                    </select>
                </div>

                <div class="col-md-2 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary w-100">Ajouter</button>
                </div>
            </form>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="text-danger mt-2">
                    @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <div>@err.ErrorMessage</div>
                    }
                </div>
            }
        </div>
    </div>

    <!-- Table -->
    <table class="table table-striped table-bordered align-middle">
        <thead class="table-dark">
            <tr>
                <th style="width:80px;">Id</th>
                <th>Nom</th>
                <th>Parcours</th>
                <th style="width:160px;">Date</th>
                <th style="width:160px;">Mode</th>
                <th style="width:120px;">Active</th>
                <th style="width:150px;">Accès</th>
                <th style="width:140px;">Action</th>
            </tr>
        </thead>

        <tbody>
            @if (!Model.Competitions.Any())
            {
                <tr><td colspan="8" class="text-center text-muted">Aucune compétition</td></tr>
            }
            else
            {
                foreach (var c in Model.Competitions)
                {
                    <tr>
                        <td>@c.Id</td>
                        <td>@c.Name</td>
                        <td>@(c.Course?.Name ?? "-")</td>
                        <td>@c.Date.ToString("dd/MM/yyyy")</td>
                        <td>@(c.ScoringMode == AFG_Livescoring.Models.ScoringMode.SquadOnly ? "Compétition" : "Entraînement")</td>
                        <td>@(c.IsActive ? "Oui" : "Non")</td>

                        <!-- Accès : Participants + Live -->
                        <td>
                            <div class="d-flex flex-column gap-2">

                                <a class="btn btn-secondary btn-sm w-100"
                                   href="/CompetitionParticipants?competitionId=@c.Id">
                                    Participants
                                </a>

                                @if (c.CourseId == null)
                                {
                                    <button class="btn btn-success btn-sm w-100"
                                            disabled
                                            title="Associe un parcours à la compétition pour activer le live">
                                        Live
                                    </button>
                                }
                                else
                                {
                                    <a class="btn btn-success btn-sm w-100"
                                       href="/Leaderboard?competitionId=@c.Id">
                                        Live
                                    </a>
                                }

                            </div>
                        </td>

                        <!-- Action : Squads + Delete -->
                        <td>
                            <div class="d-flex flex-column gap-2">

                                <a class="btn btn-outline-primary btn-sm w-100"
                                   href="/Squads/Manage?competitionId=@c.Id">
                                    Squads
                                </a>

                                <form method="post" asp-page-handler="Delete" asp-route-id="@c.Id" class="m-0">
                                    <button type="submit"
                                            class="btn btn-danger btn-sm w-100"
                                            onclick="return confirm('Supprimer la compétition ?');">
                                        Supprimer
                                    </button>
                                </form>

                            </div>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>